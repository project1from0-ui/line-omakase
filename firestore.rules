rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Tenant document: only the owner can read/write
    match /tenants/{tenantId} {
      allow read, write: if request.auth != null
        && resource != null
        && resource.data.ownerId == request.auth.uid;

      // Allow create if authenticated (new tenant setup)
      allow create: if request.auth != null
        && request.resource.data.ownerId == request.auth.uid;

      // Users subcollection: only the tenant owner can access
      match /users/{userId} {
        allow read, write: if request.auth != null
          && get(/databases/$(database)/documents/tenants/$(tenantId)).data.ownerId == request.auth.uid;

        // Messages subcollection
        match /messages/{messageId} {
          allow read: if request.auth != null
            && get(/databases/$(database)/documents/tenants/$(tenantId)).data.ownerId == request.auth.uid;
        }
      }
    }

    // Tenant query: allow listing tenants where ownerId matches
    match /tenants/{tenantId} {
      allow list: if request.auth != null
        && request.auth.uid == resource.data.ownerId;
    }
  }
}
